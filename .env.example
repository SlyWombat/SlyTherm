# Copy to .env and fill in. .env is gitignored — NEVER COMMIT real secrets.
# These credentials mirror the sibling ElectricRV projects (cPanel / EasyWeb)
# and are only needed if you publish the docs site to electricrv.ca.

# cPanel API (docs hosting / deploy)
CPANEL_HOST=
CPANEL_PORT=2083
CPANEL_USER=
CPANEL_TOKEN=

# MySQL (only if a data-logging backend is added)
MYSQL_HOST=
MYSQL_DB=
MYSQL_USER=
MYSQL_PASS=

# Web root — e.g. served at https://electricrv.ca/dettson/
WEB_ROOT=

# --- Firmware / runtime secrets (used by build-time header generation, not committed) ---
WIFI_SSID=
WIFI_PASSWORD=
MQTT_HOST=
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
