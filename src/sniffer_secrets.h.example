// sniffer_secrets.h.example — template for src/sniffer_secrets.h.
//
//   cp src/sniffer_secrets.h.example src/sniffer_secrets.h
//
// then fill in your values. src/sniffer_secrets.h is GITIGNORED — never
// commit real credentials (same rule as .env and thermostat_secrets.h).
// If the file is absent (or SSID left empty) the sniffer starts its own
// SoftAP instead (sniffer_config.h kApSsid/kApPass) so the web console
// still works on a bench with no Wi-Fi.
//
// The MQTT values are used only when built with -DSNIFFER_MQTT AND the
// push is toggled on from the web console (runtime default: off).

#pragma once

#define SNIFFER_WIFI_SSID ""
#define SNIFFER_WIFI_PASS ""
#define SNIFFER_MQTT_HOST ""
#define SNIFFER_MQTT_PORT 1883
#define SNIFFER_MQTT_USER ""
#define SNIFFER_MQTT_PASS ""
