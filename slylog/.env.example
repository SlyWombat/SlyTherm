# SlyLog configuration — copy to .env and adjust. One file configures the stack.

# --- SlyTherm sources (read-only) ---
BROKER=192.168.10.12
BROKER_PORT=1883
CONTROLLER_IP=192.168.10.13
CONTROLLER_PORT=23

# --- Weather (Open-Meteo, keyless) — Mississauga, ON ---
LAT=43.59
LON=-79.64
FORECAST_HOURS=48
TZ=America/Toronto

# --- Postgres / TimescaleDB ---
POSTGRES_USER=slylog
POSTGRES_PASSWORD=change-me
POSTGRES_DB=slylog

# --- Grafana ---
GRAFANA_PORT=3300
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# --- Predictor / Ollama ---
OLLAMA_MODEL=qwen2.5:7b-instruct
PREDICT_INTERVAL_H=4
OLLAMA_TIMEOUT_S=900
# weather-source confidence review (#141)
CONFIDENCE_INTERVAL_H=24
CONFIDENCE_STAGGER_S=1800
CONFIDENCE_WINDOW_DAYS=7

# --- Migration: host path of the historical capture archives (mounted ro) ---
LEGACY_CAPTURES=/home/dave/SlyTherm/captures

# --- Persistence root: MUST be on the big data LV, not the root LV ---
# (kdocker2 convention: /data hosts all stack data; root LV is ~87% full)
DATA_DIR=/data/slylog
